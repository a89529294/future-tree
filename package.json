{
  "name": "vending-machine",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "PORT=3002 node --env-file=.env .output/server/index.mjs",
    "prod": "NODE_ENV=production pnpm run build && NODE_ENV=production pnpm run start",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier",
    "check": "tsc --noEmit && prettier --write . && eslint --fix",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:push:prod": "NODE_ENV=production drizzle-kit push",
    "db:seed:prod": "NODE_ENV=production tsx --env-file=.env src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
